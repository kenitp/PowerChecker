# Copy this file to .env and fill in your values.
# This file is read at compile time by build.rs via the `dotenv` crate
# (same role as the original load_credentials.py in the C++ / PlatformIO project).
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   cargo build --release

WIFI_SSID=your_wifi_ssid
WIFI_PASS=your_wifi_password

# Full URL to the power checker API endpoint.
# Only literal IPv4 addresses are supported (no DNS lookup at runtime).
# Example: http://192.168.1.10/api/power
POWER_CHECKER_URL=http://192.168.0.1/api/power
